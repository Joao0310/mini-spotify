{
  "info": {
    "name": "MiniSpotify",
    "_postman_id": "minispotify-collection",
    "description": "Coleção gerada a partir dos controllers Spring Boot do MiniSpotify",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" }
  ],
  "item": [
    {
      "name": "Artistas",
      "item": [
        {
          "name": "Criar Artista",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/artistas", "host": ["{{baseUrl}}"], "path": ["artistas"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Nome do Artista\",\n  \"generoMusical\": \"Pop\",\n  \"paisOrigem\": \"Brasil\"\n}"
            }
          }
        },
        {
          "name": "Listar Artistas",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/artistas", "host": ["{{baseUrl}}"], "path": ["artistas"] }
          }
        },
        {
          "name": "Buscar Artista por ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/artistas/1", "host": ["{{baseUrl}}"], "path": ["artistas", "1"] }
          }
        },
        {
          "name": "Atualizar Artista",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/artistas/1", "host": ["{{baseUrl}}"], "path": ["artistas", "1"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Nome Atualizado\",\n  \"generoMusical\": \"Rock\",\n  \"paisOrigem\": \"Brasil\"\n}"
            }
          }
        },
        {
          "name": "Deletar Artista",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/artistas/1", "host": ["{{baseUrl}}"], "path": ["artistas", "1"] }
          }
        }
      ]
    },
